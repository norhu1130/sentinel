{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Attach by Process ID",
			"processId": "${command:PickProcess}",
			"request": "attach",
			"skipFiles": [
				"<node_internals>/**"
			],
			"type": "pwa-node"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debugger with clean build",
			"args": ["${workspaceFolder}/dist/main.js"],
			"protocol": "inspector",
			"internalConsoleOptions": "openOnSessionStart",
			"env": {
				"NODE_ENV": "development"
			},
			"skipFiles": ["<node_internals>/**", "node_modules/tslib/**"],
			"console": "internalConsole",
			"outputCapture": "std",
			"outFiles": ["${workspaceFolder}/dist/**/*.js"],
			"preLaunchTask": "npm: cleanbuild",
			"sourceMaps": true
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debugger with built code",
			"args": ["${workspaceFolder}/dist/main.js"],
			"protocol": "inspector",
			"internalConsoleOptions": "openOnSessionStart",
			"env": {
				"NODE_ENV": "development"
			},
			"skipFiles": ["<node_internals>/**", "node_modules/tslib/**"],
			"console": "internalConsole",
			"outputCapture": "std",
			"outFiles": ["${workspaceFolder}/dist/**/*.js"],
			"sourceMaps": true
		}
	]
}
