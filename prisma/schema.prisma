generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Schedule {
  id        Int      @id @default(autoincrement())
  task_id   String
  time      DateTime
  recurring String?
  // JSON.stringified data
  data      String?

  @@map("schedules")
}

// ACTUAL MODELS FOR THE FEATURES OF THIS BOT //

// Channels in which you need to send an attachment with your message to have it sendable //

model MessageOnlyChannel {
  channel_id String @id
  guild_id   String

  @@map("message_only_channels")
}

// Guild ban syncing //

model SharedGuildBan {
  user_id  String  @id
  guild_id String
  reason   String?

  @@map("shared_guild_bans")
}

// Recurring messages in channels for things like announcements //

model AutoPin {
  id                  String   @id @default(cuid())
  content             String
  button_link         String?
  button_label        String?
  channel_id          String
  guild_id            String
  check_every_seconds BigInt
  last_check          DateTime
  last_message_id     String?

  @@map("auto_pins")
}

// VOTE KICK //

model VoteKick {
  id                           String   @id @default(uuid()) @db.Uuid
  // Vote created at
  created_at                   DateTime @default(now())
  // User who is getting voted out
  user_to_kick                 String
  // User who started the vote
  started_by                   String
  // Users who agree with the vote
  voters_agreeing_with_kick    String[]
  // Users who disagree with the vote
  voters_disagreeing_with_kick String[]
  // Message to original vote kick
  message_url                  String
  // Channel in which the vote was started
  voice_channel_id             String
  // The reason for the voice kick (optional in db to help migrating)
  reason                       String?

  @@map("vote_kick")
}

model User {
  id             String    @id @unique
  // Amount of kicks in the past 6 hours
  kicks          Int
  // When to remove the blocked role from the user
  remove_role_at DateTime?
  // When to reset the kick counter
  reset_kicks_at DateTime?

  @@map("user")
}

model GuildMember {
  userId  String
  guildId String

  syncVisibleRanks Boolean @default(false)

  @@id([userId, guildId])
  @@map("guild_member")
}

// Polls! //

model Poll {
  id         String       @id @default(cuid())
  // The actual question asked
  question   String
  // The options for the poll (always at least two)
  options    String[]
  // When the poll was created
  created_at DateTime     @default(now())
  // When the poll will end
  ends_at    DateTime
  // If the poll ended
  ended      Boolean      @default(false)
  // The guild where the poll was created
  guild_id   String
  // The channel where the poll was created
  channel_id String
  // The message id for the sent message
  message_id String
  // The user who created the poll (just to have!)
  author_id  String
  // The poll answers
  answers    PollAnswer[]

  @@map("polls")
}

model PollAnswer {
  // Which poll this answer is for
  poll_id      String
  // The user that selected the option
  user_id      String
  // The option index they chose (while risky to use a number, the options are static once created)
  option_index Int

  // The poll this answer is for
  poll Poll @relation(fields: [poll_id], references: [id], onDelete: Cascade)

  @@id([poll_id, user_id])
  @@map("poll_answers")
}

// Role syncing across guilds (lord help) //

enum RoleSyncType {
  /// Sync a role across guilds
  AcrossGuilds
  /// Sync a role across the same guild for visisble rank roles (currently used for the premium role and rank roles)
  VisibleRank
}

model RoleSync {
  id                   String @id @default(cuid())
  // The origin guild from where to monitor role changes
  origin_guild_id      String
  // The role id in the origin guild that should trigger this role sync when encountered
  origin_role_id       String
  // The destination guild id where this role sync should apply
  destination_guild_id String
  // The destination role id in the destination guild that should be triggered by this role sync
  destination_role_id  String

  /// The type of role sync
  type RoleSyncType @default(AcrossGuilds)

  @@map("role_syncs")
}

// Invite pruning //
model InvitePrune {
  /// The id of the guild in which to filter invites
  /// An existing entry means we should consider the guild.
  guild_id String @id

  @@map("invite_prunes")
}

// Notifications //
model Notification {
  id        String @id @default(cuid())
  content   String
  channelId String
  guildId   String
  roleId    String

  @@map("notifications")
}

model UserNotification {
  userId         String
  notificationId String
  notifiedAt     DateTime @default(now())

  @@id([userId, notificationId])
  @@map("user_notifications")
}

// PREMIUM ROLES //
model PremiumGuildRoleConfig {
  guildId String @id

  /// The role that can be gifted by premium members
  legendRoleId String?

  /// The category in which the clan channels should be created
  clanCategoryId String?

  /// The channel in which clan invites should be sent
  clanInviteChannelId String?
  
  /// The channel in which the clan directory should be updated
  clanDirectoryChannelId String? 
  
  /// The message ID of the clan directory message
  clanDirectoryMessageId String? 

  /// The roles whose colors should be checked for custom premium roles so that the color is not too similar
  staffRoles String[]

  /// The role to use as starting position for the custom premium roles, with a fallback to the original premium role
  startingPositionRoleId String?

  @@map("premium_guild_role_configs")
}

model PremiumMember {
  guildId String
  userId  String

  customRoleId       String?
  giftedRoleToUserId String?

  giftingCooldown DateTime?

  @@id([guildId, userId])
  @@map("premium_members")
}

model ForbiddenRoleName {
  guildId          String
  rawPattern       String
  processedPattern String

  @@id([guildId, rawPattern])
  @@map("forbidden_role_names")
}

model RoleAbilities {
  guildId String
  roleId  String

  canCreateCustomRole    Boolean @default(false)
  canGiftLegend          Boolean @default(false)
  canCreateClan          Boolean @default(false)
  areAbilitiesMultiGuild Boolean @default(false)

  @@id([guildId, roleId])
  @@map("role_abilities")
}

model Clan {
  guildId      String
  customRoleId String

  channelId       String
  isRoleClaimable Boolean      @default(true)
  members         ClanMember[]
  deletionTaskId  Int?
  
  description     String?

  @@id([guildId, customRoleId])
  @@map("clan")
}

model ClanMember {
  clan             Clan   @relation(fields: [clanGuildId, clanCustomRoleId], references: [guildId, customRoleId])
  clanGuildId      String
  clanCustomRoleId String
  userId           String

  claimedRole Boolean

  @@id([clanGuildId, clanCustomRoleId, userId])
  @@map("clan_member")
}
