		"@sapphire/stopwatch": "^1.5.2",
		"@sapphire/time-utilities": "^1.7.12",
		"@sapphire/type": "^2.4.4",
		"@sapphire/utilities": "^3.15.3",
		"colorette": "^2.0.20",
