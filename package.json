		"@typescript-eslint/eslint-plugin": "^6.19.1",
		"@typescript-eslint/parser": "^6.19.1",
		"cross-env": "^7.0.3",
		"eslint": "^8.56.0",
		"eslint-config-neon": "^0.1.57",
		"eslint-formatter-pretty": "^6.0.1",
		"lodash.merge": "^4.6.2",
		"prettier": "^3.2.4",
		"prisma": "^5.8.1",
		"rimraf": "^5.0.5",
		"typescript": "^5.3.3"
	},
	"dependencies": {
