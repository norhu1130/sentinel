{
	"name": "@vladfrangu/flokie-utils-bot",
	"version": "1.1.0",
	"type": "module",
	"main": "dist/main.js",
	"scripts": {
		"start": "npm run cleanbuild && node .",
		"lint": "prettier --check . && cross-env TIMING=1 eslint --format=pretty src",
		"format": "prettier --write . && cross-env TIMING=1 eslint --fix --format=pretty src",
		"build": "tsc",
		"cleanbuild": "rimraf dist && tsc",
		"watch": "npx tsc-watch --onSuccess \"node .\"",
		"dev": "npm run start"
	},
	"private": true,
	"author": "Vlad Frangu <kingdgrizzle@gmail.com>",
	"license": "MIT",
	"devDependencies": {
